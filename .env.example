# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (PostgreSQL) ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=forever_planner
DB_USER=ENVY
DB_PASSWORD=yourpassword
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── Rate limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── External APIs ────────────────────────────────────────────
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Google OAuth (from console.cloud.google.com)
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret

# App URL (for OAuth callback + invite links)
APP_URL=https://your-app.onrender.com

# Session (use same value as JWT_SECRET is fine)
SESSION_SECRET=same_long_random_string

# Email (optional — invites still work, link is logged to console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=you@gmail.com